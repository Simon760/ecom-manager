rules_version = '2';

// ============================================================
// FIRESTORE SECURITY RULES — ecom-manager
// Single-user app : chaque utilisateur n'accède qu'à ses données
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper : vérifie que l'utilisateur est connecté ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Helper : vérifie que l'userId correspond ---
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Users ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // --- Daily Stats ---
    match /daily_stats/{statId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // --- Expenses ---
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // --- Revenues ---
    match /revenues/{revenueId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // --- Creatives ---
    match /creatives/{creativeId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // --- Products ---
    match /products/{productId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Bloque tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
